@page "/preferences"
@using Crs.Core.Enums
@inject AuthService AuthService
@inject PreferencesService PreferencesService
@inject ThemeService ThemeService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Preferences - CRS</PageTitle>

<div class="page-container preferences-page">
    <div class="preferences-layout">
        <div class="preferences-sidebar">
            <div class="preferences-editor-card">
                <h2>Theme</h2>
                <div class="theme-options">
                    <button class="@(ThemeService.IsDarkMode ? "btn-primary" : "btn-secondary")" @onclick="() => SetThemeAsync(true)">
                        Dark
                    </button>
                    <button class="@(!ThemeService.IsDarkMode ? "btn-primary" : "btn-secondary")" @onclick="() => SetThemeAsync(false)">
                        Light
                    </button>
                </div>
            </div>

            <div class="preferences-editor-card">
                <h2>@(_editingContentId.HasValue ? "Edit Content" : "Add Content")</h2>

                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="error-message">@_errorMessage</div>
                }

                @if (!string.IsNullOrWhiteSpace(_successMessage))
                {
                    <div class="success-message">@_successMessage</div>
                }

                <EditForm Model="_formModel" OnValidSubmit="HandleSubmitAsync">
                    <DataAnnotationsValidator />
                    <div class="form-grid">
                        <div class="form-group form-group-wide">
                            <label for="content-title">Title</label>
                            <InputText id="content-title" @bind-Value="_formModel.Title" class="form-input" placeholder="e.g. Distill article on transformers" />
                            <ValidationMessage For="@(() => _formModel.Title)" />
                        </div>

                        <div class="form-group">
                            <label for="content-type">Content Type <span class="optional">(optional)</span></label>
                            <InputSelect id="content-type" @bind-Value="_formModel.ContentType" class="form-input">
                                <option value="">Select...</option>
                                @foreach (var type in Enum.GetValues<ContentType>())
                                {
                                    <option value="@type">@GetContentTypeDisplay(type)</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="form-group">
                            <label for="content-vote">Feedback</label>
                            <InputSelect id="content-vote" @bind-Value="_formModel.VoteType" class="form-input">
                                <option value="@VoteType.Upvote">Upvote</option>
                                <option value="@VoteType.Downvote">Downvote</option>
                            </InputSelect>
                        </div>

                        <div class="form-group form-group-wide">
                            <label for="content-url">URL <span class="optional">(optional)</span></label>
                            <InputText id="content-url" @bind-Value="_formModel.Url" class="form-input" placeholder="https://example.com/article" />
                            <ValidationMessage For="@(() => _formModel.Url)" />
                        </div>

                        <div class="form-group form-group-wide">
                            <label for="content-description">Description <span class="optional">(optional)</span></label>
                            <InputTextArea id="content-description" @bind-Value="_formModel.Description" class="form-input preference-textarea" placeholder="What about this content did you like or dislike?" />
                            <ValidationMessage For="@(() => _formModel.Description)" />
                        </div>
                    </div>

                    <div class="preferences-form-actions">
                        <button type="submit" class="btn-primary" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : _editingContentId.HasValue ? "Save Changes" : "Add Content")
                        </button>
                        @if (_editingContentId.HasValue)
                        {
                            <button type="button" class="btn-secondary" @onclick="ResetForm" disabled="@_isSaving">Cancel</button>
                        }
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="preferences-list-card">
            <div class="preferences-list-header">
                <h2>Saved Content</h2>
                <span class="preferences-count">@_content.Count item@(_content.Count == 1 ? "" : "s")</span>
            </div>

            @if (_isLoading)
            {
                <p>Loading content...</p>
            }
            else if (!_content.Any())
            {
                <div class="empty-state">
                    <h3>No content yet</h3>
                    <p>Add a few liked or disliked examples to give the recommendation system more signal.</p>
                </div>
            }
            else
            {
                <div class="preferences-list">
                    @foreach (var content in _content)
                    {
                        <div class="preference-row">
                            <div class="preference-vote @GetVoteCss(content.VoteType)">
                                @(content.VoteType == VoteType.Upvote ? "Upvote" : "Downvote")
                            </div>
                            <div class="preference-content">
                                <div class="preference-meta">
                                    @if (content.ContentType.HasValue)
                                    {
                                        <span class="content-type-badge">@GetContentTypeDisplay(content.ContentType.Value)</span>
                                    }
                                    <span class="content-date">@FormatDate(content.UpdatedAt)</span>
                                </div>
                                <h3 class="content-row-title">
                                    @if (!string.IsNullOrWhiteSpace(content.Url))
                                    {
                                        <a href="@content.Url" target="_blank" rel="noopener">@content.Title</a>
                                    }
                                    else
                                    {
                                        <span>@content.Title</span>
                                    }
                                </h3>
                                @if (!string.IsNullOrWhiteSpace(content.Description))
                                {
                                    <p class="content-row-description">@content.Description</p>
                                }
                            </div>
                            <div class="preference-actions">
                                <button class="action-btn" @onclick="() => StartEdit(content)" disabled="@_isSaving" title="Edit">Edit</button>
                                <button class="action-btn danger-text" @onclick="() => DeleteContentAsync(content.Id)" disabled="@_isSaving" title="Delete">Delete</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly List<PreferenceItem> _content = new();
    private ContentFormModel _formModel = new();
    private Guid? _editingContentId;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            ThemeService.OnThemeChanged += StateHasChanged;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.EnsureAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadContentAsync();
    }

    private async Task LoadContentAsync()
    {
        _isLoading = true;
        _content.Clear();
        _content.AddRange(await PreferencesService.GetPreferencesAsync());
        _isLoading = false;
    }

    private async Task HandleSubmitAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;
        var wasEditing = _editingContentId.HasValue;

        var request = new PreferenceUpsertRequest
        {
            Title = _formModel.Title,
            Description = _formModel.Description,
            Url = _formModel.Url,
            ContentType = _formModel.ContentType,
            VoteType = _formModel.VoteType
        };

        PreferenceItem? savedContent = wasEditing
            ? await PreferencesService.UpdatePreferenceAsync(_editingContentId!.Value, request)
            : await PreferencesService.CreatePreferenceAsync(request);

        if (savedContent == null)
        {
            _errorMessage = "We couldn't save that content. Please try again.";
            _isSaving = false;
            return;
        }

        await LoadContentAsync();
        ResetForm();
        _successMessage = wasEditing ? "Content updated." : "Content added.";
        _isSaving = false;
    }

    private void StartEdit(PreferenceItem content)
    {
        _editingContentId = content.Id;
        _errorMessage = null;
        _successMessage = null;
        _formModel = new ContentFormModel
        {
            Title = content.Title,
            Description = content.Description,
            Url = content.Url,
            ContentType = content.ContentType,
            VoteType = content.VoteType
        };
    }

    private async Task DeleteContentAsync(Guid contentId)
    {
        _errorMessage = null;
        _successMessage = null;

        var deleted = await PreferencesService.DeletePreferenceAsync(contentId);
        if (!deleted)
        {
            _errorMessage = "We couldn't delete that content. Please try again.";
            return;
        }

        if (_editingContentId == contentId)
        {
            ResetForm();
        }

        await LoadContentAsync();
        _successMessage = "Content deleted.";
    }

    private async Task SetThemeAsync(bool isDarkMode)
    {
        await ThemeService.SetThemeAsync(isDarkMode);
    }

    private void ResetForm()
    {
        _editingContentId = null;
        _formModel = new ContentFormModel();
    }

    private static string GetContentTypeDisplay(ContentType type) => type switch
    {
        ContentType.BlogPost => "Blog Post",
        _ => type.ToString()
    };

    private static string GetVoteCss(VoteType voteType) => voteType == VoteType.Upvote ? "vote-up" : "vote-down";

    private static string FormatDate(DateTime dateTime)
    {
        var local = dateTime.ToLocalTime();
        return local.ToString("MMM d, yyyy");
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }

    private sealed class ContentFormModel
    {
        [Required(ErrorMessage = "Title is required")]
        [StringLength(500, ErrorMessage = "Title cannot exceed 500 characters")]
        public string Title { get; set; } = string.Empty;

        [StringLength(5000, ErrorMessage = "Description cannot exceed 5000 characters")]
        public string? Description { get; set; }

        [Url(ErrorMessage = "Invalid URL format")]
        [StringLength(2000, ErrorMessage = "URL cannot exceed 2000 characters")]
        public string? Url { get; set; }

        public ContentType? ContentType { get; set; }

        public VoteType VoteType { get; set; } = VoteType.Upvote;
    }
}
