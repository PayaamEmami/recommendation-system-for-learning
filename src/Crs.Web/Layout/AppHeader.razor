@inject AuthService AuthService
@inject NavigationManager NavigationManager

<header class="app-header">
    <div class="header-content">
        <a href="/feeds" class="logo">CRS</a>

        <nav class="main-nav">
            <NavLink href="/feeds" class="nav-link" Match="NavLinkMatch.All">Feeds</NavLink>
            <NavLink href="/preferences" class="nav-link" Match="NavLinkMatch.Prefix">Preferences</NavLink>
            <NavLink href="/sources" class="nav-link" Match="NavLinkMatch.Prefix">Sources</NavLink>
        </nav>

        <div class="header-actions">
            <div class="user-menu">
                <span class="user-name">@AuthService.CurrentState.DisplayName</span>
                <button @onclick="HandleLogout" class="btn-text">Logout</button>
            </div>
        </div>
    </div>
</header>

@code {
    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
