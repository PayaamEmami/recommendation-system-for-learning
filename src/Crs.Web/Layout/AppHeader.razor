@inject AuthService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<header class="app-header">
    <div class="header-content">
        <a href="/feeds" class="logo">CRS</a>

        <nav class="main-nav">
            <NavLink href="/feeds" class="nav-link" Match="NavLinkMatch.All">Feeds</NavLink>
            <NavLink href="/sources" class="nav-link" Match="NavLinkMatch.Prefix">Sources</NavLink>
        </nav>

        <div class="header-actions">
            <div class="user-menu" tabindex="0" @ref="_userMenuRef" @onfocusout="HandleUserMenuFocusOut" @onkeydown="HandleUserMenuKeyDown">
                <button class="user-menu-trigger" @onclick="ToggleUserMenu" aria-expanded="@_isUserMenuOpen" aria-haspopup="menu">
                    <span class="user-name">@AuthService.CurrentState.DisplayName</span>
                </button>

                @if (_isUserMenuOpen)
                {
                    <div class="user-menu-dropdown" role="menu">
                        <a href="/preferences" class="user-menu-item" @onclick="CloseUserMenu">Preferences</a>
                        <button class="user-menu-item" @onclick="HandleLogout">Logout</button>
                    </div>
                }
            </div>
        </div>
    </div>
</header>

@code {
    private bool _isUserMenuOpen;
    private ElementReference _userMenuRef;

    private void ToggleUserMenu()
    {
        _isUserMenuOpen = !_isUserMenuOpen;
    }

    private void CloseUserMenu()
    {
        _isUserMenuOpen = false;
    }

    private async Task HandleUserMenuFocusOut(FocusEventArgs _)
    {
        if (!_isUserMenuOpen)
        {
            return;
        }

        await Task.Yield();

        var hasFocusWithin = await JSRuntime.InvokeAsync<bool>("userMenu.hasFocusWithin", _userMenuRef);
        if (!hasFocusWithin)
        {
            _isUserMenuOpen = false;
        }
    }

    private void HandleUserMenuKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            _isUserMenuOpen = false;
        }
    }

    private async Task HandleLogout()
    {
        _isUserMenuOpen = false;
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
